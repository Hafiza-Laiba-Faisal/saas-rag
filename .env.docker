# =============================================================================
# TenBit RAG Platform — Docker Environment Variables
# =============================================================================
# Copy this file to .env and edit the values before running docker compose.
# This file is automatically copied into the container as .env
# =============================================================================

# ── LLM Configuration ──────────────────────────────────────────────────────────
RAG_LLM_API_KEY=your-gemini-or-openai-api-key-here
RAG_LLM_PROVIDER=gemini
RAG_LLM_MODEL=gemini-2.5-flash-lite

# ── Qdrant Configuration (auto-detected via docker-compose) ────────────────────
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# ── RAG Root Directory (container path) ────────────────────────────────────────
RAG_ROOT_DIR=/app/.rbs_rag

# ── OCR Service Configuration ──────────────────────────────────────────────────
MISTRAL_API_KEY=
OCR_API_KEY=

# ── Scraper Service Configuration ──────────────────────────────────────────────
DEEPCRAWL_API_KEY=