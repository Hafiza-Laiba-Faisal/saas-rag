# =============================================================================
# TenBit RAG Platform — Docker Environment Variables
# =============================================================================
# Copy this file to .env and edit the values before running docker compose.
# This file is automatically copied into the container as .env
# =============================================================================

# ── LLM Configuration ──────────────────────────────────────────────────────────
# Optional — each tenant provides their own LLM API key.
# Leave empty if you only want per-tenant keys:
RAG_LLM_API_KEY=
RAG_LLM_PROVIDER=gemini
RAG_LLM_MODEL=gemini-2.5-flash-lite

# ── Qdrant Configuration (auto-detected via docker-compose) ────────────────────
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# ── RAG Root Directory (container path) ────────────────────────────────────────
RAG_ROOT_DIR=/app/.rbs_rag

# ── Security ───────────────────────────────────────────────────────────────────
# Encryption key for API keys at rest (AES-256-GCM via Fernet)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
RAG_ENCRYPTION_KEY=

# Admin dashboard JWT secret and password
# Set both to enable admin auth; leave RAG_ADMIN_JWT_SECRET empty to disable auth
RAG_ADMIN_JWT_SECRET=
RAG_ADMIN_PASSWORD=admin

# Terminal endpoint (set to false to disable)
RAG_TERMINAL_ENABLED=true

# ── OCR Service Configuration ──────────────────────────────────────────────────
# Optional — PaddleOCR runs locally when MISTRAL_API_KEY is empty
MISTRAL_API_KEY=
OCR_API_KEY=
# NVIDIA Nemotron OCR v2 (runs as local NIM container at localhost:8000)
NEMOTRON_API_KEY=

# ── Scraper Service Configuration ──────────────────────────────────────────────
# Optional — only needed for Cloudflare bypass
DEEPCRAWL_API_KEY=