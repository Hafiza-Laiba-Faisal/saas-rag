# RAG_ROOT_DIR must be writable
RAG_ROOT_DIR=/data/.rbs_rag
RAG_ENV=production

# LLM Provider (optional — global fallback only)
# Each tenant provides their own LLM API key when created via the API/dashboard.
# Leave empty to require per-tenant keys:
RAG_LLM_API_KEY=
RAG_LLM_PROVIDER=gemini
RAG_LLM_MODEL=gemini-2.5-flash-lite

# Embedding Provider (hash = lightweight, no external API)
RAG_EMBEDDING_PROVIDER=hash
RAG_EMBEDDING_DIMENSIONS=384
RAG_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Qdrant Vector Database
RAG_QDRANT_HOST=qdrant
RAG_QDRANT_PORT=6333
RAG_QDRANT_GRPC_PORT=6334
RAG_QDRANT_API_KEY=
RAG_QDRANT_HTTPS=false

# Redis Cache (optional, for production scale)
RAG_REDIS_HOST=redis
RAG_REDIS_PORT=6379
RAG_REDIS_PASSWORD=

# Security
# Encryption key for API keys at rest (AES-256-GCM via Fernet)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
RAG_ENCRYPTION_KEY=
# Admin dashboard JWT secret (set to enable auth; leave empty to disable)
RAG_ADMIN_JWT_SECRET=
RAG_ADMIN_PASSWORD=admin
# Terminal endpoint
RAG_TERMINAL_ENABLED=true
RAG_CORS_ORIGINS=["*"]
RAG_ADMIN_AUTH_ENABLED=false

# OCR Service (standalone microservice)
MISTRAL_API_KEY=
NEMOTRON_API_KEY=
OCR_LANGUAGES=en

# Scraper — Cloudflare bypass (curl_cffi is auto-installed in Docker)
# For sites behind Cloudflare, the fetcher uses a 3-tier fallback:
#   httpx → curl_cffi (TLS fingerprint) → Playwright (full browser)
# You can optionally set a DeepCrawl API key as a final fallback:
DEEPCRAWL_API_KEY=
# Scraper limits (applied server-side, overridable per request)
SCRAPER_MAX_PAGES=200
SCRAPER_MAX_DEPTH=10

# Observability
RAG_LOG_LEVEL=INFO
RAG_STRUCTURED_LOGGING=true
