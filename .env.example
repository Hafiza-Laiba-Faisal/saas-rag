# RAG_ROOT_DIR must be writable
RAG_ROOT_DIR=/data/.rbs_rag
RAG_ENV=production

# LLM Provider
RAG_LLM_API_KEY=your-gemini-or-openai-api-key
RAG_LLM_PROVIDER=gemini
RAG_LLM_MODEL=gemini-2.5-flash-lite

# Embedding Provider (hash = lightweight, no external API)
RAG_EMBEDDING_PROVIDER=hash
RAG_EMBEDDING_DIMENSIONS=384
RAG_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Qdrant Vector Database
RAG_QDRANT_HOST=qdrant
RAG_QDRANT_PORT=6333
RAG_QDRANT_GRPC_PORT=6334
RAG_QDRANT_API_KEY=
RAG_QDRANT_HTTPS=false

# Redis Cache (optional, for production scale)
RAG_REDIS_HOST=redis
RAG_REDIS_PORT=6379
RAG_REDIS_PASSWORD=

# Security
RAG_ADMIN_AUTH_ENABLED=false
RAG_CORS_ORIGINS=["*"]

# OCR Service (standalone microservice)
MISTRAL_API_KEY=
OCR_LANGUAGES=en

# Scraper Service (standalone microservice)
DEEPCRAWL_API_KEY=

# Observability
RAG_LOG_LEVEL=INFO
RAG_STRUCTURED_LOGGING=true
