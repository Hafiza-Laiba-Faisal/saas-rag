# OCR Service Configuration
# Copy this file to .env and adjust values as needed.

# Maximum allowed file size in megabytes (default: 50)
MAX_FILE_SIZE_MB=50

# Minimum number of embedded text characters for a PDF page to be considered
# a "digital" page (skips full-page OCR if at or above this threshold) (default: 20)
MIN_TEXT_CHARS_THRESHOLD=20

# DPI at which scanned PDF pages are rendered before OCR (default: 150)
PAGE_RENDER_DPI=150

# Comma-separated list of OCR languages (default: en,ur,ar)
OCR_LANGUAGES=en,ur,ar

# Log level: DEBUG, INFO, WARNING, ERROR (default: INFO)
LOG_LEVEL=INFO

# Whether to use GPU for PaddleOCR inference (default: false)
USE_GPU=false

# Minimum image DPI; images below this threshold are upscaled before OCR (default: 150)
MIN_IMAGE_DPI=150

# Service version string (default: 1.0.0)
SERVICE_VERSION=1.0.0

MISTRAL_API_KEY="nnVYz5VNo0upl97hLVgWMGRrDw4HFzDG"
